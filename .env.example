# GitHub (Read-Only) — PAT needs read:org + repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_ORG=your-org-name

# Linear
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx
LINEAR_TEAM_ID=LAT

# Gemini (add as many keys as you want — more keys = better rate limit rotation)
GEMINI_API_KEY_1=AIzaSy...
GEMINI_API_KEY_2=AIzaSy...
GEMINI_API_KEY_3=AIzaSy...
# GEMINI_API_KEY_4=AIzaSy...
# GEMINI_API_KEY_5=AIzaSy...
# ... no limit

# Tuning (optional — defaults shown)
POLL_INTERVAL_SECONDS=120
BATCH_SIZE=3
BATCH_TIMEOUT_SECONDS=3600
WORKSPACE_REFRESH_SECONDS=1800
LOG_LEVEL=INFO
DRY_RUN=false

# Per-user exclusion — comma-separated GitHub usernames to skip task creation for
# Their commits are still tracked (SHA advances) but no Linear tasks are created
# EXCLUDED_GITHUB_USERS=bot-user,intern-account
